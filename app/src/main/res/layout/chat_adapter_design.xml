<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:id="@+id/layout_chat_message_left"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentStart="true"
        android:visibility="gone"
        tools:visibility="gone">

        <TextView
            android:id="@+id/tv_chat_left_message_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginVertical="@dimen/margin_padding_size_large"
            android:textSize="@dimen/text_size_large"
            android:textColor="@color/md_theme_outline"
            android:visibility="gone"
            tools:visibility="visible"
            tools:text="25.05.2026"/>

        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom|start"
            android:padding="@dimen/margin_padding_size_xsmall">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/civ_chat_left_user_profile_image"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginStart="@dimen/margin_padding_size_medium"
                android:contentDescription="Back arrow"
                android:src="@drawable/default_profile_pic" />

            <LinearLayout
                android:id="@+id/layout_chat_left_user_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="@dimen/margin_padding_size_large"
                android:layout_marginStart="@dimen/margin_padding_size_medium"
                android:background="@drawable/bg_left_chat_message_container">

                <TextView
                    android:id="@+id/tv_chat_left_user_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_large"
                    tools:text="Some long message" />

            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/chat_message_left_space"
            android:layout_width="match_parent"
            android:layout_height="@dimen/margin_padding_size_large"
            android:visibility="gone"
            tools:visibility="visible"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_chat_message_right"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentEnd="true"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tv_chat_right_message_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginVertical="@dimen/margin_padding_size_large"
            android:textSize="@dimen/text_size_large"
            android:textColor="@color/md_theme_outline"
            android:visibility="gone"
            tools:visibility="visible"
            tools:text="25.05.2026"/>

        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom|end"
            android:layout_gravity="end"
            android:padding="@dimen/margin_padding_size_xsmall">

            <LinearLayout
                android:id="@+id/layout_chat_right_user_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="@dimen/margin_padding_size_large"
                android:layout_marginEnd="@dimen/margin_padding_size_medium"
                android:background="@drawable/bg_right_chat_message_container">

                <TextView
                    android:id="@+id/tv_chat_right_user_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_large"
                    android:textColor="@color/md_theme_onSecondary"
                    tools:text="Some long message" />

            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/chat_message_right_space"
            android:layout_width="match_parent"
            android:layout_height="@dimen/margin_padding_size_large"
            android:visibility="gone"
            tools:visibility="visible"/>

    </LinearLayout>

</RelativeLayout>