<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout android:id="@+id/layout_home_user_comment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/margin_padding_size_medium"
        android:background="@color/md_theme_background">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/civ_home_user_new_comment_profile_image"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/default_profile_pic"
            android:contentDescription="Company profile image" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/margin_padding_size_large">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_home_user_name_new_comment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    tools:text="Filip Ivanovski"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_padding_size_medium"
                    android:text="·"
                    android:textSize="@dimen/text_size_medium"/>

                <TextView
                    android:id="@+id/tv_home_comment_time_submited"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_padding_size_small"
                    android:textSize="@dimen/text_size_medium"
                    tools:text="45m"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_home_user_comment_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_medium"
                tools:text="Dobra ponuda!"/>

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/md_theme_outlineVariant"/>

</LinearLayout>
