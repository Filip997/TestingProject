<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_container_account"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".account.presentation.fragments.UserAccountFragment">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingHorizontal="@dimen/margin_padding_size_large"
        android:background="@color/md_theme_primaryContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_back_arrow_account"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/ic_arrow_back_green"
            android:scaleType="fitXY"
            android:contentDescription="Settings"
            android:layout_gravity="center_vertical|start"
            android:visibility="gone"
            tools:visibility="visible"/>

        <ImageView
            android:id="@+id/iv_settings_account"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/ic_settings"
            android:scaleType="fitXY"
            android:contentDescription="Settings"
            android:layout_gravity="center_vertical|end"/>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_user_info_account"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin_padding_size_xlarge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/layout_user_followers_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/layout_user_profile_image"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/tv_followers_text_account"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/followers"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    tools:text="Followers"/>

                <TextView
                    android:id="@+id/tv_followers_num_account"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_medium"
                    tools:text="25"/>

            </LinearLayout>

            <FrameLayout
                android:id="@+id/layout_user_profile_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_padding_size_large"
                android:gravity="center"
                android:paddingHorizontal="@dimen/margin_padding_size_medium"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_user_profile_picture_account"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/default_profile_pic"
                    app:civ_border_color="@color/md_theme_primary"
                    app:civ_border_width="4dp" />

                <LinearLayout
                    android:id="@+id/layout_edit_profile_picture_account"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="@dimen/margin_padding_size_xlarge"
                    android:layout_marginBottom="@dimen/margin_padding_size_medium"
                    android:background="@drawable/bg_edit_icon"
                    android:gravity="center"
                    android:padding="@dimen/margin_padding_size_medium">

                    <ImageView
                        android:id="@+id/iv_edit_profile_picture_account"
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:contentDescription="Edit"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_edit" />

                </LinearLayout>

            </FrameLayout>

            <TextView
                android:id="@+id/tv_user_full_name_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="@dimen/margin_padding_size_medium"
                android:textSize="@dimen/text_size_large_title"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layout_user_profile_image"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:text="Filip Ivanovski"/>

            <LinearLayout
                android:id="@+id/layout_user_following_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                app:layout_constraintStart_toEndOf="@+id/layout_user_profile_image"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/tv_following_text_account"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/following"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    tools:text="Following"/>

                <TextView
                    android:id="@+id/tv_following_num_account"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_medium"
                    tools:text="15"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/layout_buttons_account"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/margin_padding_size_xxxxlarge"
            android:layout_marginTop="@dimen/margin_padding_size_xlarge"
            android:orientation="horizontal"
            android:gravity="center_horizontal">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/margin_padding_size_large">

                <ToggleButton
                    android:id="@+id/tglbtn_follow_account"
                    android:layout_width="120dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_account_follow_btn"
                    android:textOff="@string/follow_btn_text"
                    android:textOn="@string/following_btn_text"
                    android:textAllCaps="false"
                    android:textColor="@color/md_theme_onSecondary" />

                <ProgressBar
                    android:id="@+id/progressbar_follow_request_account"
                    android:layout_width="@dimen/margin_padding_size_xxxxlarge"
                    android:layout_height="@dimen/margin_padding_size_xxxxlarge"
                    android:layout_gravity="center"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/md_theme_secondaryContainer"
                    android:visibility="gone"
                    android:elevation="@dimen/margin_padding_size_xlarge"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </FrameLayout>

            <Button
                android:id="@+id/btn_message_account"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_account_message_btn"
                android:text="@string/message"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_person_reactions_comments_account"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_user_info_account"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="@dimen/margin_padding_size_large"
            android:background="@color/md_theme_outlineVariant"/>

        <RadioGroup
            android:id="@+id/rg_tabs_account"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/margin_padding_size_xlarge"
            android:paddingHorizontal="@dimen/margin_padding_size_xxxxlarge">

            <RadioButton
                android:id="@+id/rb_reactions_person_account"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:background="@drawable/bg_account_reactions_comments"
                android:button="@null"
                android:checked="true"
                android:gravity="center"
                android:paddingTop="@dimen/margin_padding_size_small"
                android:text="@string/reactions"
                android:textColor="@drawable/text_color_account_reactions_comments"
                android:textSize="@dimen/text_size_large_title"
                android:textStyle="bold"/>

            <View
                android:layout_width="@dimen/margin_padding_size_xxxxlarge"
                android:layout_height="1dp" />

            <RadioButton
                android:id="@+id/rb_comments_person_account"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:background="@drawable/bg_account_reactions_comments"
                android:button="@null"
                android:checked="false"
                android:gravity="center"
                android:paddingTop="@dimen/margin_padding_size_small"
                android:text="@string/comments"
                android:textColor="@drawable/text_color_account_reactions_comments"
                android:textSize="@dimen/text_size_large_title"
                android:textStyle="bold"/>

        </RadioGroup>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_posts_account"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="@dimen/margin_padding_size_xlarge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_person_reactions_comments_account"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_bump_line_account"
            android:layout_width="match_parent"
            android:layout_height="45dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:src="@drawable/ic_bump_line"
                android:scaleType="fitXY"
                android:contentDescription="Bump Line"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_padding_size_small"
                android:text="@string/posts"
                android:textColor="@color/md_theme_primary"
                android:textSize="@dimen/text_size_large_title"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_posts_account"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/md_theme_secondaryContainer"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layout_line_separation_account" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressbar_account"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:elevation="@dimen/margin_padding_size_xxlarge"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>